# Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGO_URI=your_mongodb_connection_string_here

# (Optional) Custom webhook URL for Vercel deployment.
# Only needed if using a custom domain. Vercel auto-detects otherwise.
# WEBHOOK_URL=https://your-custom-domain.com
