{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/set_webhook.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.py" },
    { "src": "/api/set_webhook", "dest": "/api/set_webhook.py" }
  ],
  "functions": {
    "api/webhook.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/set_webhook.py": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
